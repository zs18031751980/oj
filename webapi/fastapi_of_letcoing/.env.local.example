# ============================================================
# 本地开发环境变量模板
# 复制此文件为 .env.local 后按需修改
# .env.local 不会被 Git 追踪，安全存放本地配置
# ============================================================

# 后端公网地址（本地开发使用 localhost）
PUBLIC_BACKEND_URL=http://localhost:6173

# 前端地址（本地开发使用 Vite 默认端口）
FRONTEND_URL=http://localhost:5173

# 允许跨域的前端域名
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# 本地 Redis（可选，不设置则使用 .env 中的线上 Redis）
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# 本地 PostgreSQL（可选，不设置则使用 .env 中的线上数据库）
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=letcoding
# DB_USER=postgres
# DB_PASSWORD=postgres
