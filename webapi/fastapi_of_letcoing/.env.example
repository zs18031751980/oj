API_TOKEN=your_glot_api_token
JWT_SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=https://your-frontend-domain.zeabur.app
ALLOWED_ORIGINS=https://your-frontend-domain.zeabur.app
PUBLIC_BACKEND_URL=https://your-backend-domain.zeabur.app

# Optional persistence / auth settings
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_TIMEOUT=5

DB_HOST=localhost
DB_PORT=5432
DB_NAME=letcoding
DB_USER=postgres
DB_PASSWORD=
DB_MAX_CONNECTIONS=20
DB_STALE_TIMEOUT=300

# Optional OAuth / OIDC
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=
IOSCLUB_REDIRECT_URI=
OIDC_PROVIDERS={}
# Example:
# OIDC_PROVIDERS={"iOSClub":{"client_id":"...","client_secret":"...","server_metadata_url":"https://api.xauat.site/.well-known/openid-configuration","client_kwargs":{"scope":"openid profile email"},"skip_id_token_validation":true}}
