# ============================================================
# 本地开发环境变量模板
# 复制此文件为 .env.local 后按需修改
# .env.local 不会被 Git 追踪，安全存放本地配置
# ============================================================

# 后端 API 地址（本地开发使用 localhost）
VITE_API_BASE_URL=http://localhost:6173

# OIDC 回调地址（指向本地后端）
VITE_IOSCLUB_REDIRECT_URI=http://localhost:6173/auth/callback/iOSClub
